<!DOCTYPE html>
<html>
<head>
  <title>Melorin's Token Clubhouse</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; text-align: center; background: #f0f2f5; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; overflow: hidden; }
    
    /* Login Screen */
    #loginScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #9c27b0; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 1000; color: white; transition: 0.5s; }
    #loginScreen input { margin: 10px; padding: 15px; border-radius: 10px; border: none; font-size: 18px; width: 220px; text-align: center; outline: none; }
    #loginScreen button { background: #4CAF50; color: white; padding: 15px 40px; border: none; border-radius: 10px; font-weight: bold; font-size: 18px; cursor: pointer; box-shadow: 0 4px 0 #2e7d32; }
    
    /* App Box */
    .box { background: white; padding: 15px; width: 95%; max-width: 440px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); position: relative; height: 94vh; display: flex; flex-direction: column; overflow: hidden; }
    
    .top-stats { display: flex; justify-content: space-around; margin-bottom: 10px; }
    .stat-pill { background: #ede7f6; color: #512da8; padding: 5px 15px; border-radius: 15px; font-size: 14px; font-weight: bold; border: 1px solid #d1c4e9; }
    
    #modeBtn { background: #9c27b0; font-size: 11px; padding: 6px 15px; border-radius: 15px; color: white; border: none; cursor: pointer; margin-bottom: 5px; align-self: center; }

    .question { font-size: 36px; font-weight: bold; margin: 5px 0; color: #333; }
    #mathInput { font-size: 28px; padding: 8px; width: 100px; border: 2px solid #ddd; border-radius: 10px; text-align: center; }
    
    .letter-grid { display: flex; justify-content: center; gap: 4px; margin: 10px 0; flex-wrap: wrap; }
    .letter-box { width: 32px; height: 42px; font-size: 20px; text-align: center; border: 2px solid #ddd; border-radius: 5px; text-transform: lowercase; font-weight: bold; }
    .letter-box:focus { border-color: #4CAF50; outline: none; background: #f0fff0; }

    #helpArea { margin: 10px 0; padding: 10px; background: #fffde7; border-radius: 12px; border: 1px dashed #fbc02d; flex-grow: 1; display: flex; flex-direction: column; overflow-y: auto; }
    .help-title { font-size: 11px; font-weight: bold; color: #856404; margin-bottom: 5px; text-transform: uppercase; }
    
    .ten-frame-grid { display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px; width: fit-content; margin: 0 auto; }
    .dot { width: 10px; height: 10px; border-radius: 50%; background: #2196F3; }
    .dot.secondary { background: #f44336; }
    .dot.dim { background: #e0e0e0; border: 1px solid #ccc; }
    
    .grid-row { display: flex; gap: 3px; justify-content: center; margin-bottom: 3px; }
    .division-group { border: 1px solid #ddd; padding: 5px; border-radius: 6px; display: inline-block; margin: 3px; background: white; }

    button#submitBtn { font-size: 20px; padding: 12px 40px; background: #4CAF50; color: white; border: none; border-radius: 15px; cursor: pointer; font-weight: bold; box-shadow: 0 4px 0 #388E3C; }
    #speakBtn { background: #2196F3; border-radius: 50%; width: 50px; height: 50px; font-size: 25px; color: white; border: none; cursor: pointer; }

    .bottom-tokens { background: #fafafa; border-top: 2px solid #eee; padding: 10px; margin-top: auto; }
    .progress-container { width: 100%; height: 20px; background: #e0e0e0; border-radius: 10px; margin: 8px 0; overflow: hidden; border: 1px solid #ccc; }
    #progressBar { height: 100%; width: 0%; background: linear-gradient(90deg, #ff5252, #ff1744); transition: width 0.5s; }
    .token-labels { display: flex; justify-content: space-between; font-size: 13px; font-weight: bold; }

    #message { font-weight: bold; font-size: 18px; margin: 5px 0; height: 30px; }
    #resetBtn { position: absolute; top: 5px; left: 5px; font-size: 9px; opacity: 0.2; background: none; border: none; cursor: pointer; }
    .confetti { position: fixed; width: 8px; height: 8px; z-index: 999; pointer-events: none; }
    @keyframes fall { 0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; } 100% { transform: translateY(110vh) rotate(720deg); opacity: 0; } }
  </style>
</head>
<body>

<div id="loginScreen">
  <h1>Clubhouse Login 🪙</h1>
  <input type="text" id="loginName" placeholder="Your Name">
  <input type="password" id="loginPin" placeholder="4-Digit PIN" maxlength="4">
  <button onclick="attemptLogin()">Enter</button>
  <p id="loginError" style="color: #ffcdd2; margin-top: 10px;"></p>
</div>

<div class="box" id="appContent" style="display:none;">
  <button id="resetBtn" onclick="resetPrompt()">Admin</button>
  <div class="top-stats">
    <div class="stat-pill">Math: <span id="mathCount">0</span>/20</div>
    <div class="stat-pill">Spell: <span id="spellCount">0</span>/30</div>
  </div>
  <button id="modeBtn" onclick="toggleMode()">Switch Mode</button>
  <div id="mathArea">
    <div class="question" id="mathQuestion"></div>
    <input type="number" id="mathInput" placeholder="?">
  </div>
  <div id="spellingArea" style="display:none;">
    <button id="speakBtn" onclick="sayWord()">🔊</button>
    <div class="letter-grid" id="letterGrid"></div>
  </div>
  <p id="message"></p>
  <button id="submitBtn" onclick="checkAnswer()">Submit</button>
  <div id="helpArea">
    <div class="help-title" id="helpTitle">Helper</div>
    <div id="visualAid"></div>
  </div>
  <div class="bottom-tokens">
    <div class="token-labels">
      <span>Today: <span id="todayTokens">0</span> / 300</span>
      <span>Total: <span id="totalTokens">0</span> 🪙</span>
    </div>
    <div class="progress-container"><div id="progressBar"></div></div>
  </div>
</div>

<script>
// Paste your URL here
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw4WeR4pIbtdlmHaD3tRgDtJa1ILasfn2M3pcgJ89Z0JPXpZCrMj7OD331k26pRj8-Eag/exec';

let user = { name: "", total: 0, math: 0, spell: 0, today: 0, logs: "" };
let mode = "math", spellingWords = [], currentWord = "";
let num1, num2, operator, correctAnswer, attempts = 0, penaltyApplied = false;

async function attemptLogin() {
    const name = document.getElementById("loginName").value.trim();
    const pin = document.getElementById("loginPin").value.trim();
    const err = document.getElementById("loginError");
    if(!name || !pin) return;
    err.innerText = "Connecting...";
    try {
        const res = await fetch(`${SCRIPT_URL}?action=login&name=${name}&pin=${pin}`);
        const data = await res.json();
        if(data === "error") { err.innerText = "Wrong name or PIN!"; }
        else {
            user = { name, ...data };
            document.getElementById("loginScreen").style.display = "none";
            document.getElementById("appContent").style.display = "flex";
            loadWords();
            updateScore();
            nextTask();
        }
    } catch(e) { err.innerText = "Server Error. Check your URL."; }
}

async function loadWords() {
    const res = await fetch(`${SCRIPT_URL}?action=getWords`);
    spellingWords = await res.json();
}

async function sync() {
    fetch(SCRIPT_URL, { method: "POST", body: JSON.stringify(user) });
}

const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
function playSound(win) {
    const osc = audioCtx.createOscillator(); const g = audioCtx.createGain();
    osc.connect(g); g.connect(audioCtx.destination);
    if(win) { osc.frequency.setValueAtTime(600, 0); osc.start(); osc.stop(0.2); }
    else { osc.type = 'sawtooth'; osc.frequency.setValueAtTime(100, 0); osc.start(); osc.stop(0.4); }
}

function createConfetti() {
    for (let i = 0; i < 40; i++) {
        const c = document.createElement('div'); c.className = 'confetti';
        c.style.left = Math.random() * 100 + 'vw';
        c.style.backgroundColor = `hsl(${Math.random() * 360}, 100%, 50%)`;
        c.style.animation = `fall ${Math.random() * 2 + 1}s linear forwards`;
        document.body.appendChild(c); setTimeout(() => c.remove(), 3000);
    }
}

function toggleMode() {
    mode = (mode === "math") ? "spelling" : "math";
    document.getElementById("mathArea").style.display = (mode === "math") ? "block" : "none";
    document.getElementById("spellingArea").style.display = (mode === "spelling") ? "block" : "none";
    nextTask();
}

function nextTask() {
    attempts = 0; penaltyApplied = false;
    document.getElementById("message").innerText = "";
    document.getElementById("visualAid").innerHTML = "";
    if (mode === "math") generateMath(); else generateSpelling();
}

function generateMath() {
    const ops = ["+", "-", "*", "/"];
    operator = ops[Math.floor(Math.random() * 4)];
    num1 = Math.floor(Math.random() * 21) + 10;
    num2 = Math.floor(Math.random() * 15) + 5;
    if (operator === "-" && num2 > num1) [num1, num2] = [num2, num1];
    if (operator === "*") { num1 = Math.floor(Math.random()*8)+2; num2 = Math.floor(Math.random()*8)+2; }
    if (operator === "/") { num2 = Math.floor(Math.random()*5)+2; let ans = Math.floor(Math.random()*6)+2; num1 = num2 * ans; }
    correctAnswer = (operator === "+") ? num1 + num2 : (operator === "-") ? num1 - num2 : (operator === "*") ? num1 * num2 : num1 / num2;
    document.getElementById("mathQuestion").innerText = `${num1} ${operator === '*' ? '×' : (operator === '/' ? '÷' : operator)} ${num2}`;
    document.getElementById("mathInput").value = ""; document.getElementById("mathInput").focus();
}

function generateSpelling() {
    currentWord = spellingWords[Math.floor(Math.random() * spellingWords.length)];
    const grid = document.getElementById("letterGrid");
    grid.innerHTML = "";
    for (let i = 0; i < currentWord.length; i++) {
        const b = document.createElement("input"); b.className = "letter-box"; b.maxLength = 1;
        if (i === 0 || i === currentWord.length - 1) { b.value = currentWord[i]; b.disabled = true; }
        else { b.oninput = (e) => { if (e.target.value && i < currentWord.length - 2) grid.children[i+1].focus(); }; }
        grid.appendChild(b);
    }
    setTimeout(sayWord, 400);
}

function sayWord() {
    window.speechSynthesis.cancel();
    let m = new SpeechSynthesisUtterance(currentWord); m.rate = 0.7; window.speechSynthesis.speak(m);
}

function checkAnswer() {
    let val = "";
    if (mode === "math") val = document.getElementById("mathInput").value;
    else document.querySelectorAll(".letter-box").forEach(b => val += b.value);
    if (!val) return;
    const isCorrect = (mode === "math") ? (parseInt(val) === correctAnswer) : (val.toLowerCase() === currentWord);

    if (isCorrect) {
        playSound(true); createConfetti();
        let r = 0;
        if (user.today < 300) {
            if (mode === "math" && user.math < 20) { r = 10; user.math++; }
            if (mode === "spelling" && user.spell < 30) { r = 15; user.spell++; }
        }
        user.total += r; user.today += r;
        document.getElementById("message").style.color = "green";
        document.getElementById("message").innerText = "Bravo Melorin! 🌟";
        sync(); updateScore(); setTimeout(nextTask, 1500);
    } else {
        attempts++; playSound(false);
        if (!penaltyApplied) {
            user.total = Math.max(0, user.total - 3); user.today = Math.max(0, user.today - 3);
            penaltyApplied = true;
            user.logs += `[${new Date().toLocaleTimeString()}] ${mode}: ${val} wrong. `;
            document.getElementById("message").style.color = "red";
            document.getElementById("message").innerText = "-3 Tokens Penalty 💨";
            sync(); updateScore();
        }
        showHelp();
    }
}

function showHelp() {
    const aid = document.getElementById("visualAid"); aid.innerHTML = "";
    const hT = document.getElementById("helpTitle");
    if (mode === "math") {
        hT.innerText = "Math Help";
        const grid = document.createElement("div"); grid.className = "ten-frame-grid";
        for(let i=0; i<num1; i++) {
            const d = document.createElement('div'); d.className = "dot"; grid.appendChild(d);
        }
        aid.appendChild(grid);
    } else {
        hT.innerText = "Spelling Tip";
        if(attempts === 2) aid.innerHTML = `Word starts with: ${currentWord[0]}... and ends with ${currentWord[currentWord.length-1]}`;
        else if(attempts >= 3) aid.innerHTML = `The word is: ${currentWord.toUpperCase()}`;
    }
}

function updateScore() {
    document.getElementById("mathCount").innerText = user.math;
    document.getElementById("spellCount").innerText = user.spell;
    document.getElementById("todayTokens").innerText = user.today;
    document.getElementById("totalTokens").innerText = user.total;
    document.getElementById("progressBar").style.width = Math.min((user.today/300)*100, 100) + "%";
}

function resetPrompt() {
    let b = Math.floor(Math.random()*4)+11;
    if (prompt(`Admin: ${b}x${b}?`) == b*b) {
        let c = prompt("1: Reset Today\n2: Reset Total\n3: Errors");
        if(c=="1") { user.math=0; user.spell=0; user.today=0; }
        else if(c=="2") { user.total=0; user.math=0; user.spell=0; user.today=0; }
        else if(c=="3") { alert(user.logs || "No errors!"); }
        sync(); updateScore();
    }
}
</script>
</body>
</html>
